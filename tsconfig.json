{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node", "jest"],
    "strict": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["proxy/**/*.ts"],
  "exclude": ["proxy/__tests__"]
}
