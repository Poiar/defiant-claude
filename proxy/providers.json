    "deepseek-v4-flash": { "type": "enabled", "budget_tokens": 16000 }
  },
  "compactionWindow": {
    "_comment": "Per-model compaction threshold (tokens). Overrides the auto-calculated value from contextLimits. DeepSeek has free disk cache lasting hours — pushing compaction near the wall preserves cache hits (98% of tokens at ~$0.0036/M vs $0.435/M miss). Compact only when genuinely needed.",
