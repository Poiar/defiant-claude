# DeepClaude — Environment Variables
# Copy this file to .env and fill in your API keys.
# Or export these variables in your shell profile (~/.bashrc, ~/.zshrc, $PROFILE).
#
# See CLAUDE.md for full documentation.

# =============================================================================
# Provider API Keys
#
# Set at least one provider key. DeepSeek (DEEPSEEK_API_KEY) is the recommended
# default — it's the cheapest and best-tested path.
# =============================================================================

# DeepSeek (direct, /anthropic endpoint) — RECOMMENDED PRIMARY
# Get a key: https://platform.deepseek.com/api-keys
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# OpenAI (direct)
# Get a key: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Anthropic (direct)
# Get a key: https://console.anthropic.com/keys
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# OpenRouter — aggregates 300+ models from all labs
# Get a key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx

# Google Gemini
# Get a key: https://aistudio.google.com/apikey
# GEMINI_API_KEY=xxxxxxxxxxxxxxxx

# xAI / Grok
# Get a key: https://console.x.ai
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxx

# Fireworks AI — DeepSeek V4 with Anthropic wire format
# Get a key: https://fireworks.ai/api-keys
# FIREWORKS_API_KEY=fw-xxxxxxxxxxxxxxxx

# OpenCode Zen — OpenCode-hosted models (big-pickle)
# Get a key: https://opencode.ai/keys
# OPENCODE_API_KEY=oc-xxxxxxxxxxxxxxxx

# Kimi / Moonshot
# KIMI_API_KEY=sk-xxxxxxxxxxxxxxxx

# Xiaomi Mimo
# MIMO_API_KEY=sk-xxxxxxxxxxxxxxxx

# Alibaba / DashScope (Qwen)
# ALIBABA_DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx

# Groq
# Get a key: https://console.groq.com/keys
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx

# Mistral
# Get a key: https://console.mistral.ai/api-keys
# MISTRAL_API_KEY=xxxxxxxxxxxxxxxx

# MiniMax
# MINIMAX_API_KEY=sk-xxxxxxxxxxxxxxxx

# Z.ai / GLM (Zhipu)
# ZAI_API_KEY=xxxxxxxxxxxxxxxx

# BytePlus / Doubao
# BYTEPLUS_API_KEY=xxxxxxxxxxxxxxxx

# SiliconFlow
# SILICONFLOW_API_KEY=sk-xxxxxxxxxxxxxxxx

# Novita
# NOVITA_API_KEY=sk-xxxxxxxxxxxxxxxx

# Umans AI
# UMANS_API_KEY=sk-xxxxxxxxxxxxxxxx


# =============================================================================
# Budget & Spend Limits
# =============================================================================

# Hard cap on daily spend in USD. Requests above this are rejected.
# Example: DEEPCLAUDE_DAILY_BUDGET=10.00  (max $10/day)
# DEEPCLAUDE_DAILY_BUDGET=

# Warning thresholds as comma-separated percentages (50,75,100).
# At each threshold, desktop notifications fire (if supported by your OS).
# Example: DEEPCLAUDE_BUDGET_WARNING=50,75,100
# DEEPCLAUDE_BUDGET_WARNING=


# =============================================================================
# Security
# =============================================================================

# AES-256-GCM master key for encrypting provider API keys on disk.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Once set, use `dc --encrypt-keys` to encrypt plaintext keys in providers.json.
# If not set, keys are stored in plaintext (still only readable by your user).
# DEEPCLAUDE_MASTER_SECRET=


# =============================================================================
# Behavior
# =============================================================================

# Auth key for the embedded dashboard (http://127.0.0.1:<port>).
# If not set, a random key is generated per startup.
# DEEPCLAUDE_DASHBOARD_KEY=

# Skip the startup health probe (checks all providers before launching CC).
# Speeds up startup when you know your providers are healthy.
# DEEPCLAUDE_SKIP_STARTUP_CHECK=true

# Timeout per upstream provider attempt (milliseconds). Default: none (CC controls).
# Useful for providers with slow first-token times.
# PROVIDER_TIMEOUT_MS=180000

# Enable debug logging (verbose output to stderr).
# DEBUG=1

# Override the default config directory (~/.deepclaude).
# DEEPCLAUDE_CONFIG_DIR=/path/to/alternate/config


# =============================================================================
# Web Search — which search engines to use for Claude Code's WebSearch tool
# =============================================================================

# Comma-separated list of engines: searxng, ddg, brave (default: searxng,ddg).
# Engines are tried in parallel; results merged & deduplicated.
# DEEPCLAUDE_SEARCH_ENGINES=searxng,ddg

# ---- Brave Search API (recommended — 2000 free calls/month) ----------------
# Get a key: https://api.search.brave.com/register
# Then add 'brave' to DEEPCLAUDE_SEARCH_ENGINES.
# DEEPCLAUDE_BRAVE_API_KEY=BSA-xxxxxxxxxxxxxxxx

# ---- SearXNG (self-hosted, free, no rate limits) ---------------------------
# docker run -d --name searxng -p 8888:8080 searxng/searxng
# DEEPCLAUDE_SEARXNG_URL=http://localhost:8888/search?format=json&q=

# ---- Offline / mock mode ---------------------------------------------------
# Return mock results for testing (no network calls).
# DEEPCLAUDE_SEARCH_NO_NETWORK=true


# =============================================================================
# Claude Code Integration (auto-set by the proxy — do NOT set manually)
# =============================================================================

# The proxy sets these before spawning Claude Code. Setting them manually
# will be overridden. They're listed here for transparency.

# ANTHROPIC_BASE_URL=http://127.0.0.1:<port>     # (auto-set)
# ANTHROPIC_AUTH_KEY=deepclaude-<port>            # (auto-set)
# CLAUDE_CODE_AUTO_COMPACT_WINDOW=<tokens>        # (auto-set per model)
