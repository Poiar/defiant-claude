#!/bin/sh
# Pre-push: catch shell / PowerShell issues before they land on the remote.
# Linting + formatting already ran at commit time, so this is lightweight.

DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAIL=0

echo ""

echo ""

# README — ensure template and data sources haven't drifted from README.md
echo "  README.md up to date..."
npx tsx "$DIR/scripts/build-readme.ts" 2>/dev/null
if ! git -C "$DIR" diff --exit-code -- README.md >/dev/null 2>&1; then
  git -C "$DIR" checkout -- README.md 2>/dev/null
  echo "  ✗ README.md is stale — run: npm run build:readme:apply && git add README.md"
  FAIL=1
fi

# Shell
echo "  bash -n..."
bash -n "$DIR/deepclaude.sh" || FAIL=1

# PowerShell (only on Windows or if pwsh available)
if command -v pwsh >/dev/null 2>&1; then
  echo "  PSScriptAnalyzer..."
  pwsh -NoProfile -Command "& { \$err=0; Get-ChildItem '$DIR/*.ps1','$DIR/*/*.ps1' -ErrorAction SilentlyContinue | ForEach-Object { \$r=Invoke-ScriptAnalyzer -Path \$_.FullName -Severity Error -ErrorAction SilentlyContinue; if(\$r) { \$r | Out-String | Write-Warning; \$err=1 } }; exit \$err }" || FAIL=1
fi

if [ "$FAIL" -ne 0 ]; then
  echo ""
  echo "Push blocked — fix the above and retry."
  exit 1
fi

echo "  OK"
echo ""
