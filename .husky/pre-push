#!/bin/sh
# Full lint pass — blocks push on any failure.
# Runs only at push time, never interrupts commits.

DIR="$(cd "$(dirname "$0")/.." && pwd)"
FAIL=0

echo ""

# TypeScript (proxy + tests)
echo "  eslint..."
npx eslint "$DIR/proxy/" --max-warnings 0 || FAIL=1

# .mjs (launcher + statusline)
echo "  node --check..."
node --check "$DIR/proxy/launcher.mjs" || FAIL=1
node --check "$DIR/statusline/statusline.mjs" || FAIL=1

# package.json (and providers.json)
echo "  JSON..."
node --eval "JSON.parse(require('node:fs').readFileSync(process.argv[1],'utf-8'))" "$DIR/package.json" || FAIL=1
node --eval "JSON.parse(require('node:fs').readFileSync(process.argv[1],'utf-8'))" "$DIR/proxy/providers.json" || FAIL=1

# Shell
echo "  bash -n..."
bash -n "$DIR/deepclaude.sh" || FAIL=1

# PowerShell (only on Windows or if pwsh available)
if command -v pwsh >/dev/null 2>&1; then
    echo "  PSScriptAnalyzer..."
    pwsh -NoProfile -Command "& { \$err=0; Get-ChildItem '$DIR/*.ps1','$DIR/*/*.ps1' -ErrorAction SilentlyContinue | ForEach-Object { \$r=Invoke-ScriptAnalyzer -Path \$_.FullName -Severity Error -ErrorAction SilentlyContinue; if(\$r) { \$r | Out-String | Write-Warning; \$err=1 } }; exit \$err }" || FAIL=1
fi

if [ "$FAIL" -ne 0 ]; then
    echo ""
    echo "Push blocked — linting failed. Fix the above and retry."
    exit 1
fi

echo "  OK"
echo ""
